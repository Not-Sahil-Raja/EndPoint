---
import { Icon } from "astro-icon/components";

export interface Props {}

const {} = Astro.props;

const BASE =
  "https://github.com/Not-Sahil-Raja/EndPoint/releases/download/app-v0.1.0";
const VERSION = "0.1.0";

const platforms = [
  {
    label: "macOS",
    icon: "apple-logo",
    borderClass: "border-r-0",
    downloads: [
      { label: "Mac (ARM64)", file: `end-point_${VERSION}_aarch64.dmg` },
      { label: "Mac (x64)", file: `end-point_${VERSION}_x64.dmg` },
    ],
  },
  {
    label: "Windows",
    icon: "windows-logo",
    borderClass: "border-r-0",
    downloads: [
      {
        label: "Windows (x64) Setup",
        file: `end-point_${VERSION}_x64-setup.exe`,
      },
      {
        label: "Windows (x64) MSI",
        file: `end-point_${VERSION}_x64_en-US.msi`,
      },
    ],
  },
  {
    label: "Linux",
    icon: "linux-logo",
    borderClass: "",
    downloads: [
      { label: "Linux .deb (x64)", file: `end-point_${VERSION}_amd64.deb` },
      { label: "Linux .rpm (x64)", file: `end-point_${VERSION}-1.x86_64.rpm` },
      {
        label: "Linux AppImage (x64)",
        file: `end-point_${VERSION}_amd64.AppImage`,
      },
    ],
  },
];
---

<section
  class="relative text-white font-jetbrains py-12 max-w-7.5xl mx-auto min-h-[70vh]"
  id="download"
>
  <div class="absolute inset-x-0 bottom-0 h-px bg-stone-50/5"></div>
  <div class="max-w-7.5xl mx-auto w-full h-full px-10 md:px-16 relative">
    <div class="absolute inset-y-0 left-4 w-px bg-stone-50/5"></div>
    <div class="absolute inset-y-0 right-4 w-px bg-stone-50/5"></div>
    <h2 class="text-xl font-semibold leading-snug text-white pb-1">
      EndPoint is available for macOS, Windows, and Linux.
    </h2>

    <div class="flex items-center gap-4 py-6 mt-6 px-1">
      <span class="text-white text-xl font-medium">v{VERSION}</span>
      <span
        class="text-xs border border-white/20 text-zinc-400 rounded-md px-2.5 py-0.5 font-medium tracking-wide uppercase"
      >
        Latest
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 mb-8">
      {
        platforms.map((platform) => (
          <div
            class={`border border-white/8 overflow-hidden px-4 bg-white/2 ${platform.borderClass}`}
          >
            <div class="flex items-center gap-2.5 py-4">
              <Icon class="w-4.5 h-4.5 text-zinc-300" name={platform.icon} />
              <span class="text-white text-sm">{platform.label}</span>
            </div>
            <div class="divide-y divide-white/6 mb-5">
              {platform.downloads.map((d) => (
                <a
                  href={`${BASE}/${d.file}`}
                  class="flex items-center justify-between py-3.5 transition-colors duration-150 group"
                >
                  <span class="text-zinc-300 text-sm group-hover:text-white transition-colors">
                    {d.label}
                  </span>
                  <Icon
                    name="solar:download-minimalistic-bold"
                    class="w-4 h-4 text-zinc-400 group-hover:text-zinc-300 transition-colors"
                  />
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <a
      href="https://github.com/Not-Sahil-Raja/EndPoint/releases/tag/app-v0.1.0"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-base text-orange-500 hover:text-orange-400 transition-colors pl-1"
    >
      View Release Notes
      <Icon name="solar:arrow-right-linear" class="w-4 h-4" />
    </a>
  </div>
</section>
