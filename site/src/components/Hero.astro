---
import { Icon } from "astro-icon/components";
import HeroBackground from "./HeroBackground.astro";

export interface Props {}

const {} = Astro.props;
---

<section
  class="relative min-h-screen text-white font-jetbrains flex flex-col overflow-hidden"
>
  <div class="absolute inset-x-0 bottom-8 lg:bottom-12 h-px bg-stone-50/5">
  </div>

  <div
    class="relative flex-1 w-full max-w-7.5xl mx-auto px-4 py-1 pb-8 lg:pb-12"
  >
    <HeroBackground />

    <div class="absolute inset-y-0 left-4 w-px bg-stone-50/5"></div>

    <div class="absolute inset-y-0 right-4 w-px bg-stone-50/5"></div>

    <div class="relative w-full h-full md:flex px-4 lg:px-8 py-4">
      <div
        class="flex flex-1 flex-col justify-center items-center md:items-start text-left px-2 lg:px-4 gap-3 min-h-[calc(100vh-6rem)]"
      >
        <h1 class="text-4xl font-bold">
          EndPoint - The Ultimate Server Monitor
        </h1>

        <h4 class="text-base leading-tight opacity-65 max-w-xl">
          A compact, intuitive, and feature-rich server monitoring tool.
        </h4>

        <div
          class="flex flex-col sm:flex-row mt-6 gap-3 sm:gap-4 items-stretch w-full"
        >
          <a
            id="download-btn"
            href="#"
            class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-xs cursor-pointer duration-150 transition-colors inline-flex items-center gap-2 justify-center"
          >
            <span id="os-icon-mac" class="hidden"
              ><Icon name="apple-logo" class="w-4 h-4" /></span
            >
            <span id="os-icon-win" class="hidden"
              ><Icon name="windows-logo" class="w-4 h-4" /></span
            >
            <span id="os-icon-linux" class="hidden"
              ><Icon name="linux-logo" class="w-4 h-4" /></span
            >
            <span id="os-icon-default"
              ><Icon
                name="solar:download-minimalistic-bold"
                class="w-4 h-4"
              /></span
            >
            <span id="download-text">Download</span>
          </a>

          <a
            href="https://github.com/Not-Sahil-Raja/EndPoint#features"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-stone-900 hover:bg-stone-950 text-white px-4 py-2 rounded-xs cursor-pointer duration-150 transition-colors inline-flex items-center gap-2 justify-center"
          >
            Explore Features
          </a>
        </div>
      </div>

      <div class="hidden md:block flex-1"></div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("download-btn") as HTMLAnchorElement;
  const text = document.getElementById("download-text")!;

  const icons = {
    mac: document.getElementById("os-icon-mac")!,
    win: document.getElementById("os-icon-win")!,
    linux: document.getElementById("os-icon-linux")!,
    default: document.getElementById("os-icon-default")!,
  };

  const ua = navigator.userAgent;

  if (ua.includes("Mac")) {
    text.textContent = "Download for macOS";
    btn.href =
      "https://github.com/Not-Sahil-Raja/EndPoint/releases/download/app-v0.1.0/end-point_0.1.0_aarch64.dmg";
    icons.default.classList.add("hidden");
    icons.mac.classList.remove("hidden");
  } else if (ua.includes("Win")) {
    text.textContent = "Download for Windows";
    btn.href =
      "https://github.com/Not-Sahil-Raja/EndPoint/releases/download/app-v0.1.0/end-point_0.1.0_x64-setup.exe";
    icons.default.classList.add("hidden");
    icons.win.classList.remove("hidden");
  } else {
    text.textContent = "Download for Linux";
    btn.href =
      "https://github.com/Not-Sahil-Raja/EndPoint/releases/download/app-v0.1.0/end-point_0.1.0_amd64.AppImage";
    icons.default.classList.add("hidden");
    icons.linux.classList.remove("hidden");
  }
</script>
